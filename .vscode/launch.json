{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Current TS File",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/ts-node",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "sourceMaps": true,
      "internalConsoleOptions": "openOnSessionStart",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    }
  ]
}
