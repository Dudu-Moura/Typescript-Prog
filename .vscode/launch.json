{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Current TS File",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx.cmd",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "sourceMaps": true,
      "env": {
        "NODE_OPTIONS": ""
      },
      "outputCapture": "std",
      "internalConsoleOptions": "openOnSessionStart",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ]
    }
  ]
}